# Enforce consistent line endings
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf diff=bash

# Markdown
*.md text eol=lf diff=markdown

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# JSON
*.json text eol=lf

# Archives (binary)
*.tar.gz binary
*.gz binary
*.zip binary

# Images (binary)
*.png binary
*.jpg binary
*.gif binary
*.ico binary
